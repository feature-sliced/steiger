{
  "name": "@feature-sliced/steiger-plugin",
  "description": "A set of rules to verify correct usage of Feature-Sliced Design",
  "version": "0.5.8",
  "scripts": {
    "build": "tsup",
    "check-formatting": "prettier --check . --cache",
    "dev": "tsup --watch",
    "format": "prettier --write . --cache",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    "import": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "THIRD-PARTY-NOTICES"
  ],
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "contributors": [
    {
      "name": "Anton Medvedev",
      "email": "unordinarity@yandex.ru",
      "url": "https://github.com/unordinarity"
    },
    {
      "name": "Lev Chelyadinov",
      "email": "leva181777@gmail.com",
      "url": "https://github.com/illright"
    }
  ],
  "homepage": "https://github.com/feature-sliced/steiger",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feature-sliced/steiger.git",
    "directory": "packages/steiger-plugin-fsd"
  },
  "dependencies": {
    "@feature-sliced/filesystem": "^3.1.0",
    "fastest-levenshtein": "^1.0.16",
    "lodash-es": "^4.17.21",
    "pluralize": "^8.0.0",
    "tsconfck": "^3.1.6",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@steiger/eslint-config": "workspace:*",
    "@steiger/toolkit": "workspace:*",
    "@steiger/tsconfig": "workspace:*",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/pluralize": "^0.0.33",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
